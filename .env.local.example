# ==========================================================
# 筋肉塾 新サイト — 環境変数テンプレート
# ==========================================================
# 使い方:
#   1. このファイルをコピーして `.env.local` を作る
#   2. `.env.local` に実際の値を記入する
#   3. `.env.local` は .gitignore 済み。絶対に git にコミットしない
#   4. 値をチャットに直接貼り付けない
# ==========================================================

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
# Project URL（Settings → API で確認）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# 公開可能なキー（Publishable Key、フロントエンド用）
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx

# 秘密の鍵（Secret Key、サーバー側のみ、絶対公開禁止）
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx


# ─────────────────────────────────────────────
# Stripe（フェーズ3 で使う）
# ─────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx


# ─────────────────────────────────────────────
# Resend（メール送信、フェーズ2 で使う）
# ─────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@juku.norifitness.com


# ─────────────────────────────────────────────
# LINE Messaging API（フェーズ3 で使う）
# ─────────────────────────────────────────────
# LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxx
# LINE_CHANNEL_SECRET=xxxxxxxxxxxx


# ─────────────────────────────────────────────
# Anthropic API（noriAI 連携、Should Have 以降）
# ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx


# ─────────────────────────────────────────────
# サイト設定
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# 本番: NEXT_PUBLIC_SITE_URL=https://juku.norifitness.com
