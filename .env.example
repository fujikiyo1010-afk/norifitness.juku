# ==========================================================
# 筋肉塾 新サイト構築プロジェクト — 環境変数テンプレート
# ==========================================================
# 使い方:
#   1. このファイルをコピーして `.env` を作る（既に作成済み）
#   2. `.env` に実際の値を記入する
#   3. `.env` は .gitignore 済み。絶対に git にコミットしない
#   4. 値をチャットに直接貼り付けない（ファイルから読み込ませる）
# ==========================================================

# --- エキスパ（現筋肉塾ツール）ログイン情報 ---
# フェーズ0 のエキスパ調査で使用
EXPA_LOGIN_URL=
EXPA_LOGIN_ID=
EXPA_PASSWORD=

# エキスパ管理画面（管理者用）
EXPA_ADMIN_URL=
EXPA_ADMIN_ID=
EXPA_ADMIN_PASSWORD=

# --- Supabase（フェーズ1以降で記入） ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- 決済プロバイダ（フェーズ1で確定後に記入） ---
# 例: STRIPE_SECRET_KEY=, STRIPE_PUBLISHABLE_KEY=

# --- noriAI 連携（フェーズ1で要否判断） ---
# ANTHROPIC_API_KEY=
